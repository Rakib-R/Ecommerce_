{
  "compileOnSave": false,
  "compilerOptions": {
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "sourceMap": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2020", //! CHANGED BY ULTIMATED CLAUED CODE  FROM ES2015
    "module": "ESNext",   //! CHANGED BY ULTIMATED CLAUED CODE FROM nodenext
    "moduleResolution": "bundler", //todo SINCE USING WEBPACK
    "lib": ["es2020"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "types": ["node"],
    "paths": {
      // "@/*": ["./*"], /// DO NOT PUT THIS
      // "@api-gateway/*": ["apps/api-gateway/src/*"], /// DO NOT PUT THIS
       "@packages/error-handler": ["packages/error-handler/src/index.ts"],
      "@packages/middleware": ["packages/middleware/src/index.ts"],
      "@packages/prisma": ["packages/libs/prisma/src/index.ts"],
      "@packages/redis": ["packages/libs/redis/src/index.ts"],
    }
  },
  "exclude": ["node_modules", "tmp"],
}
