{
  "name": "api-gateway",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api-gateway/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "defaultConfiguration": "development",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/api-gateway",
        "main": "apps/api-gateway/src/main.ts",
        "tsConfig": "apps/api-gateway/tsconfig.app.json",

        "watch": false,
        "isolatedModules": true,
        "webpackConfig": "apps/api-gateway/webpack.config.cjs"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production",
          "watch": false
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "api-gateway:build",
        "runtimeArgs": ["--env-file=.env"],
        "inspect": false,
        "runBuildTargetDependencies": false,
          "watch": false

      },
      "configurations": {
        "development": {
          "buildTarget": "api-gateway:build:development",
          "watch": false

        },
        "production": {
          "buildTarget": "api-gateway:build:production",
          "watch": false

        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    }
  }
}