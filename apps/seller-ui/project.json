
{
  "name": "seller-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/seller-ui",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project seller-ui --web",
  
  "targets": {

  "build": {
  "executor": "@nx/next:build",
  "options": {
    "outputPath": "dist/apps/seller-ui"
  },
  "configurations": {
    "development": {
        "buildTarget": "seller-ui:build:development",
        "dev": true,
        "port": 4000,
        "turbo": true  
      },
    "production": {}
  }
},
  "serve": {
    "executor": "@nx/next:server",
    "options": {
      "buildTarget": "seller-ui:build",
      "dev": true,
      "port": 4000,
      "turbo": true
    },
    "configurations": {
      "development": {
        "buildTarget": "seller-ui:build:development",
        "dev": true,
        "port": 4000
      },
      "production": {
        "buildTarget": "seller-ui:build:production",
        "dev": false,
        "port": 4000
      }
    }
  }
}

}
