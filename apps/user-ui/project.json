{
  "name": "user-ui",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "options": {
        "outputPath": "dist/apps/user-ui",
        "tailwindConfig": "apps/user-ui/tailwind.config.js",
        "postcssConfig": "apps/user-ui/postcss.config.js"
      },
      "configurations": {
        "development": {
          "outputPath": "tmp/apps/user-ui"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "options": {
        "buildTarget": "user-ui:build",
        "dev": true,
        "port": 3000,
        "host": "localhost"
      },
      "configurations": {
        "development": {
          "buildTarget": "user-ui:build:development"
        },
        "production": {
          "buildTarget": "user-ui:build:production"
        }
      }
    }
  }
}