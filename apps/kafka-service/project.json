{
  "name": "kafka-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/kafka-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/kafka-service",
        "main": "apps/kafka-service/src/main.ts",
        "tsConfig": "apps/kafka-service/tsconfig.json",
        "webpackConfig": "apps/kafka-service/webpack.config.js",
        "generatePackageJson": true
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "kafka-service:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "kafka-service:build:development"
        },
        "production": {
          "buildTarget": "kafka-service:build:production"
        }
      }
    }
  }
}