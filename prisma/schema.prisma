

generator client {
  provider = "prisma-client-js" //!!  NUCLEAR FIX     NUCLEAR FIX    NUCLEAR FIX    NUCLEAR FIX    NUCLEAR FIX    NUCLEAR FIX  
                                  //!!  ADD -JS    ADD -JS    ADD -JS    ADD -JS    ADD -JS  
  // output   = "../packages/libs/prisma/src/generated"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model images {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  file_id   String
  url       String
  shopId    String? @db.ObjectId @unique
  userId    String? @db.ObjectId @unique
  shop      shops? @relation(fields: [shopId], references: [id])
  user      users?  @relation(fields: [userId], references: [id])
  products  product? @relation(fields: [productId], references: [id])
  productId String? @db.ObjectId @unique
}

model users {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String   @unique
  password    String
  following   String[]
  avatar      images?
  shopReviews shopReviews[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model shopReviews {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  shopId      String?  @db.ObjectId
  rating      Float
  review      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      users    @relation(fields: [userId], references: [id])
  shop      shops?   @relation(fields: [shopId], references: [id])
}

model sellers {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String    @unique
  phone_number String
  country      String
  password     String
  stripeId     String?
  shop         shops?   
  stripeOnboarded Boolean  @default(false) 
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model shops {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  bio         String?
  category    String
  avatar      images?
  coverBanner  String?
  address      String
  opening_hours String?
  website      String?
  socialLinks  Json?
  ratings      Float?
  reviews    shopReviews[] 
  sellers    sellers      @relation(fields: [sellerId], references: [id])
  sellerId   String       @unique @db.ObjectId
  product    product[]    

  createdAt  DateTime      @default(now())
  updatedAt  DateTime     @updatedAt
 }

 model site_config {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  categories    String[]
  subCategories Json
}

model discount_codes {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  public_name   String
  discountType  String
  discountValue Float
  discountCode  String   @unique
  sellerId      String   @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product       product? @relation("ProductDiscountCodes", fields: [productId], references: [id])
  productId     String?  @db.ObjectId
}

// Separate type for structured image data
type Image {
  fileId   String
  file_url String
}

enum productStatus{
  Active
  Pending
  Draft
}

model product {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  slug                String   @unique
  category            String
  subCategory         String
  description         String
  detailed_description String 
  images              images[] 
  tags                String[]
  colors              String[] @default([])
  sizes               String[] @default([])
  
  video_url           String?
  brand               String?
  regular_price       Float
  ratings             Float   @default(5)
  warranty            String?
  sale_price          Float?   @default(0)
  stock               Int      @default(0)
  custom_specification Json?
  custom_property      Json?
  isDeleted            Boolean? @default(false)
  cashOnDelivery       String 
  status               productStatus  @default(Active)
  shopId               String  @db.ObjectId
  Shop                 shops   @relation(fields: [shopId], references: [id])

  // AI Assistance Defined ERROR
  discount_codes  discount_codes[] @relation("ProductDiscountCodes")
  totalSales  Int      @default(0) 
  
  // Meta
  createdAt           DateTime @default(now())
  starting_date       DateTime?
  ending_date         DateTime?
  deleteAt            DateTime?
  updatedAt           DateTime @updatedAt
}

