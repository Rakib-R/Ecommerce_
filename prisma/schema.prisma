

generator client {
  provider = "prisma-client-js" //!!  NUCLEAR FIX     NUCLEAR FIX    NUCLEAR FIX    NUCLEAR FIX    NUCLEAR FIX    NUCLEAR FIX  
                                  //!!  ADD -JS    ADD -JS    ADD -JS    ADD -JS    ADD -JS  
  // output   = "../packages/libs/prisma/src/generated"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model images {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  file_id   String
  url       String
  shopId    String? @db.ObjectId @unique
  userId    String? @db.ObjectId @unique
  shop      shops? @relation(fields: [shopId], references: [id])
  user      users?  @relation(fields: [userId], references: [id])
}

model users {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String   @unique
  password    String
  following   String[]
  avatar      images?
  shopReviews shopReviews[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model shopReviews {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  shopId      String?  @db.ObjectId
  rating      Float
  review      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      users    @relation(fields: [userId], references: [id])
  shop      shops?   @relation(fields: [shopId], references: [id])
}

model sellers {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String    @unique
  phone_number String
  country      String
  password     String
  stripeId     String?
  shop         shops?   
  stripeOnboarded Boolean  @default(false) 
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model shops {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  bio         String?
  category    String
  avatar      images?
  coverBanner  String?
  address      String
  opening_hours String?
  website      String?
  socialLinks  Json?
  ratings      Float?
  reviews    shopReviews[] 
  sellers    sellers      @relation(fields: [sellerId], references: [id])
  sellerId   String       @unique @db.ObjectId
  createdAt  DateTime      @default(now())
  updatedAt  DateTime     @updatedAt
 }