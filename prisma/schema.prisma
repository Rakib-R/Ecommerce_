

generator client {
  provider = "prisma-client-js" //!!  NUCLEAR FIX     NUCLEAR FIX    NUCLEAR FIX    NUCLEAR FIX  
                                  //!!  ADD -JS    ADD -JS    ADD -JS    ADD -JS    ADD -JS  
  // output   = "../packages/libs/prisma/src/generated"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model images {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  file_id      String
  url          String
  productId    String?    @db.ObjectId
  userAvatarsId      String?    @db.ObjectId
  sellerAvatarsId    String?    @db.ObjectId
  coverShopId  String?    @db.ObjectId

  coverShop   shops?        @relation(fields: [coverShopId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sellerAvatar sellers?    @relation(fields: [sellerAvatarsId], references: [id], onDelete: NoAction, onUpdate: NoAction) 
  userAvatar    users?       @relation(fields: [userAvatarsId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products   product?       @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([userAvatarsId])
  @@index([sellerAvatarsId])
  @@index([coverShopId])
}

model users {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String   @unique
  password    String

  address     address[]
  following   shop_followed[]
  avatar      images[]
  shopReviews shopReviews[]
  analytics   userAnalytics? 
  order       Order[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model sellers {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String    @unique
  phone_number String
  country      String
  password     String
  stripeId     String?
  
  avatar      images[]
  
  shop         shops?
  product      product[]

  productDiscounts productDiscount[]
  discount_codes discount_codes[]

  stripeOnboarded Boolean  @default(false) 
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model shops {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  category      String
  address       String
  
  coverBanner   String?
  coverShop     images[]
  bio           String?
  opening_hours String?
  website       String?
  socialLinks   Json?
  ratings       Float?
  reviews       shopReviews[] 
  
  sellerId     String  @unique @db.ObjectId  
  seller       sellers @relation(fields: [sellerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
      
  products     product[]
  order        Order[]
  followers    shop_followed[] 
  analytics    productAnalytics[]

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
 }

 model shop_followed {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId   
  shopId          String    @db.ObjectId

  follower         users    @relation(fields: [userId], references: [id])
  following_shops  shops    @relation(fields: [shopId], references: [id])
  @@unique([userId, shopId]) 
 }

enum SendingAddressType {
  SHIPPING
  BILLING
}

enum addressType{
  HOME
  WORK
  OTHER
}

model address {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  type      SendingAddressType @default(SHIPPING)
  label     addressType
  name      String?
  street    String
  city      String
  zip       String?
  country   String
  userId    String  @db.ObjectId
  user      users   @relation(fields: [userId], references: [id])
  isDefault Boolean 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model shopReviews {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  shopId      String   @db.ObjectId
  rating      Float?
  review      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      users    @relation(fields: [userId], references: [id])
  shop      shops    @relation(fields: [shopId], references: [id])
}


 model site_config {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  categories    String[]
  subCategories Json
}

model productDiscount {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  productId       String    @db.ObjectId
  sellerId        String    @db.ObjectId
  discountCodeId  String    @db.ObjectId
  createdAt       DateTime  @default(now())

  seller         sellers        @relation(fields: [sellerId], references: [id])
  product        product        @relation(fields: [productId], references: [id])
  discountCode   discount_codes @relation(fields: [discountCodeId], references: [id])

  @@unique([productId, discountCodeId])
}

model discount_codes {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  public_name      String
  discountType     String
  discountValue    Float
  discountCode     String            @unique
  sellerId         String            @db.ObjectId
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  seller           sellers           @relation(fields: [sellerId], references: [id])
  productDiscounts productDiscount[] // ← navigate to products through this
}

enum productStatus{
  Active
  Pending
  Draft
}

model product {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  slug                String   @unique
  category            String
  subCategory         String
  short_description   String
  detailed_description String 
  images              images[] 
  tags                String[]
  colors              String[] @default([])
  sizes               String[] @default([])
  
  video_url           String?
  brand               String?
  regularPrice        Float
  ratings             Float     @default(5)
  warranty            String?
  salePrice           Float?    @default(0)
  stock               Int       @default(0)
  custom_specification Json?
  custom_property      Json?
  isDeleted            Boolean? @default(false)
  cashOnDelivery       Boolean 
  cash_on_delivery     String?
  status               productStatus  @default(Active)
  analytics            productAnalytics?
  totalSales           Int      @default(0) 

  shopId               String   @db.ObjectId
  Shop                 shops    @relation(fields: [shopId], references: [id])

  sellerId             String   @db.ObjectId
  seller               sellers  @relation(fields: [sellerId], references: [id])

  paymentStatus       PaymentStatus @default(UNPAID)
  paymentMethod       PaymentMethod?
  
  // AI Assistance Patched Inconsistency
  discount_codes       productDiscount[]
  Order                OrderItem[]
  
  // Meta
  createdAt           DateTime @default(now())
  starting_date       DateTime
  ending_date         DateTime?
  deleteAt            DateTime?
  updatedAt           DateTime @updatedAt

  // ✅ Index for filtering
  @@index([shopId])
  @@index([sellerId])
  @@index([category])

  // ✅ Compound indexes for common queries
  @@index([shopId, status])      // Shop + status filter
  @@index([category, status])     // Category + status
  @@index([createdAt, status]) 
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  CARD
  BANK_TRANSFER
  MOBILE_BANKING
}

model Order {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber   String    @unique
  userId        String    @db.ObjectId
  shopId        String    @db.ObjectId
  total         Float
  subtotal      Float
  shippingCost  Float
  discount      Float         @default(0)
  items         OrderItem[]
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod
  shippingAddress Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          users     @relation(fields: [userId], references: [id])
  shop          shops     @relation(fields: [shopId], references: [id])
}

model OrderItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String   @db.ObjectId
  productId String   @db.ObjectId
  productName String
  productImage String?
  quantity  Int
  price     Float    // Price at time of purchase
  total     Float    // quantity * price
  size      String?
  color     String?
  
  order     Order    @relation(fields: [orderId], references: [id])
  product   product  @relation(fields: [productId], references: [id])
}

model userAnalytics {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId  // ← used in where clause
  lastTrained   DateTime?
  country        String?
  city           String?
  
  // extraFields —
  totalVisits    Int?      @default(1)
  actions       Json     // ← updatedActions (array/object of user actions)
  pageViews      Json?    // { "/home": 5, "/product": 3 }
  device        String?  // mobile, desktop
  browser        String?
  referrer       String?
  sessionCount   Int?      @default(1)
  lastAction     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastVisited     DateTime?
  user          users     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model productAnalytics {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  productId     String   @unique @db.ObjectId
  shopId        String?  @db.ObjectId
  views         Int      @default(0)
  cartAdds      Int      @default(0)
  wishListAdds  Int      @default(0)
  purchases     Int      @default(0)
  lastViewedAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  product       product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop          shops?    @relation(fields: [shopId], references: [id])

}